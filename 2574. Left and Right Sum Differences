class Solution {
    public int[] leftRightDifference(int[] nums) {
        int lSum = 0;
        int rSum = 0;
        for(int num : nums){
            rSum += num;
        }
        int res[] = new int[nums.length];
        for(int i=0; i<nums.length; i++){
            rSum -= nums[i];
            res[i] = Math.abs(lSum-rSum);
            lSum += nums[i];
        }
        return res;
    }
}
