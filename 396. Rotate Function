class Solution {
    public int maxRotateFunction(int[] nums) {
        int fk = 0;
        int sum = 0;
        for(int i=0; i<nums.length; i++){
            fk += nums[i]*i;
            sum += nums[i];
        }
        int res = fk;
        for(int i=nums.length-1; i>0; i--){
            fk += sum - nums.length*nums[i];
            res = Math.max(fk,res);
        }
        return res;
    }
}
