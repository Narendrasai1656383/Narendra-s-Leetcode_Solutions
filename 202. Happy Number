class Solution {
    public boolean isHappy(int n) {
        HashSet<Integer> set = new HashSet<>();
        set.add(n);
        while(true){
            n = findHappyNumber(n);
            if(n == 1){
                return true;
            }
            if(set.contains(n)){
                return false;
            }
            set.add(n);
        }
    }
    private int findHappyNumber(int n){
        int res = 0;
        while(n > 0){
            res += Math.pow(n%10,2);
            n = n/10;
        }
        return res;
    }
}
