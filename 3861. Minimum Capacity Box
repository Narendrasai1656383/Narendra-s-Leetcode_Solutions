class Solution {
    public int minimumIndex(int[] capacity, int itemSize) {
        int min = Integer.MAX_VALUE;
        for(int i=0; i< capacity.length; i++){
            if(min > capacity[i] && capacity[i]>=itemSize){
                min = capacity[i];
            }
            if(min == itemSize){
                return i;
            }
        }
        for(int i=0; i< capacity.length; i++){
            if(min == capacity[i]){
                return i;
            }
        }
        return -1;
    }
}
