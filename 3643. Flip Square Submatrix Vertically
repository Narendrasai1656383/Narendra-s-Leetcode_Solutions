class Solution {
    public int[][] reverseSubmatrix(int[][] grid, int x, int y, int k) {
        for(int i=x,i1=x+k-1; i<i1; i++,i1--){
            for(int j=y; j<y+k; j++){
                int temp = grid[i][j];
                grid[i][j] = grid[i1][j];
                grid[i1][j] = temp;
            }
        }
        return grid;
    }
}
