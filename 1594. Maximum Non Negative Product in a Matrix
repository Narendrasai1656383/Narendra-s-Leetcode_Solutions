class Solution {
    public int maxProductPath(int[][] grid) {
        long[][] max = new long[grid.length][grid[0].length];
        long[][] min = new long[grid.length][grid[0].length];
        max[0][0] = min[0][0] = grid[0][0];
        for(int i=1; i<grid[0].length;i++){
            max[0][i] = min[0][i] = grid[0][i] * max[0][i-1];
        }
        for(int i=1; i<grid.length;i++){
            max[i][0] = min[i][0] = grid[i][0] * max[i-1][0];
        }
        for(int i=1; i<grid.length; i++){
            for(int j=1; j<grid[0].length; j++){
                if(grid[i][j]<0){
                    max[i][j] = Math.min(min[i][j-1],min[i-1][j])*grid[i][j];
                    min[i][j] = Math.max(max[i][j-1],max[i-1][j])*grid[i][j];
                }else{
                    max[i][j] = Math.max(max[i][j-1],max[i-1][j])*grid[i][j];
                    min[i][j] = Math.min(min[i][j-1],min[i-1][j])*grid[i][j];
                }
            }
        }
        return max[grid.length-1][grid[0].length-1] >= 0 ? (int)(max[grid.length-1][grid[0].length-1]%1000000007) : -1;
    }
}
